    item [5]:
        class = "IntervalTier"
        name = "transcript"
        xmin = 0
        xmax = 600.000000
        intervals: size = 96
        intervals [1]:
            xmin = 0.000000
            xmax = 0.100000
            text = ""
        intervals [2]:
            xmin = 0.100000
            xmax = 12.320000
            text = "as it were. There are 3 different stages to the design. I'm not really sure what you guys have already received in your emails. What did you get?"
        intervals [3]:
            xmin = 12.320000
            xmax = 13.379000
            text = ""
        intervals [4]:
            xmin = 13.379000
            xmax = 18.430000
            text = "I just got the project announcement, but what project is that? Designing a remote control?"
        intervals [5]:
            xmin = 18.430000
            xmax = 19.480000
            text = ""
        intervals [6]:
            xmin = 19.480000
            xmax = 46.810000
            text = "Is that what everybody got? Okay. We're going to have— individual work and then a meeting about it and repeat that process 3 times. At this point we get to try out the whiteboard over there. You get to draw your favorite animal and sum up your favorite characteristics of it. Who would like to go first?"
        intervals [7]:
            xmin = 46.810000
            xmax = 47.910000
            text = "I'll go."
        intervals [8]:
            xmin = 47.910000
            xmax = 48.780000
            text = "Very good."
        intervals [9]:
            xmin = 48.780000
            xmax = 53.750000
            text = ""
        intervals [10]:
            xmin = 53.750000
            xmax = 63.400000
            text = "Alright, so this one here, right?"
        intervals [11]:
            xmin = 63.400000
            xmax = 64.100000
            text = "Mm-hmm."
        intervals [12]:
            xmin = 64.100000
            xmax = 95.389000
            text = "Okay, very nice. Alright, my favorite animal is like A beagle. And character— favorite characteristics of it, is that right?"
        intervals [13]:
            xmin = 95.389000
            xmax = 96.064000
            text = ""
        intervals [14]:
            xmin = 96.064000
            xmax = 96.289000
            text = "Yeah."
        intervals [15]:
            xmin = 96.289000
            xmax = 96.691000
            text = ""
        intervals [16]:
            xmin = 96.691000
            xmax = 123.220000
            text = "Uh, right, well, basically, um, high priority for any animal for me is that they be willing to take a lot of physical affection from their family. And yeah, they have lots of personality and be fit and in robust good health. So this is Blue, Blue Beagle, my family's beagle."
        intervals [17]:
            xmin = 123.220000
            xmax = 125.350000
            text = "Right, lovely."
        intervals [18]:
            xmin = 125.350000
            xmax = 134.960000
            text = ""
        intervals [19]:
            xmin = 134.960000
            xmax = 141.550000
            text = "My favourite animal would be a monkey."
        intervals [20]:
            xmin = 141.550000
            xmax = 143.869000
            text = ""
        intervals [21]:
            xmin = 143.869000
            xmax = 153.660000
            text = "They're small, cute, and furry, and when Planet of the Apes becomes real, I'm going to be up there with them."
        intervals [22]:
            xmin = 153.660000
            xmax = 156.720000
            text = ""
        intervals [23]:
            xmin = 156.720000
            xmax = 166.140000
            text = "Right. There's too much gear."
        intervals [24]:
            xmin = 166.140000
            xmax = 173.490000
            text = "You can take as long over this as you like because we haven't got an awful lot to discuss. Oh, cool. We do. We do. Don't feel like you're in a rush anyway."
        intervals [25]:
            xmin = 173.490000
            xmax = 174.520000
            text = ""
        intervals [26]:
            xmin = 174.520000
            xmax = 176.000000
            text = "Okay."
        intervals [27]:
            xmin = 176.000000
            xmax = 177.930000
            text = "I could have told you a whole lot more about Beagles."
        intervals [28]:
            xmin = 177.930000
            xmax = 178.060000
            text = ""
        intervals [29]:
            xmin = 178.060000
            xmax = 183.760000
            text = "Okay, too. We might have to get you up again then. I don't know what mine is, I'm gonna have to think on the spot now."
        intervals [30]:
            xmin = 183.760000
            xmax = 187.380000
            text = ""
        intervals [31]:
            xmin = 187.380000
            xmax = 188.840000
            text = "Impressionist."
        intervals [32]:
            xmin = 188.840000
            xmax = 191.879000
            text = "Can't draw."
        intervals [33]:
            xmin = 191.879000
            xmax = 193.240000
            text = "Is that a whale?"
        intervals [34]:
            xmin = 193.240000
            xmax = 221.840000
            text = "Yeah. Eh! Um, oh my, I don't know, it's just the first animal I can think of off the top of my head. I guess big reason is because I'm allergic to most animals. Logic to animal first, so fish was a natural choice. Yeah, and I kind of like whales. They come in and go, ""Hrrr,"" eat everything in sight. They're quite harmless and mild and interesting."
        intervals [35]:
            xmin = 221.840000
            xmax = 222.840000
            text = ""
        intervals [36]:
            xmin = 222.840000
            xmax = 225.530000
            text = "Okay, I still don't know what I'm gonna write about."
        intervals [37]:
            xmin = 225.530000
            xmax = 229.480000
            text = ""
        intervals [38]:
            xmin = 229.480000
            xmax = 231.480000
            text = "Superb sketch, by the way."
        intervals [39]:
            xmin = 231.480000
            xmax = 234.770000
            text = ""
        intervals [40]:
            xmin = 234.770000
            xmax = 256.850000
            text = "I was going to choose a dog as well, but I'll just draw a different kind of dog. My favourite animal is my own dog at home. That doesn't really look like him actually. He looks more like a pig actually. Oh well."
        intervals [41]:
            xmin = 256.850000
            xmax = 258.189000
            text = ""
        intervals [42]:
            xmin = 258.189000
            xmax = 259.809000
            text = "I see a dog in there."
        intervals [43]:
            xmin = 259.809000
            xmax = 261.479000
            text = "Do you? Oh, that's very good of you."
        intervals [44]:
            xmin = 261.479000
            xmax = 262.649000
            text = ""
        intervals [45]:
            xmin = 262.649000
            xmax = 263.939000
            text = "Now I see a rooster."
        intervals [46]:
            xmin = 263.939000
            xmax = 268.369000
            text = ""
        intervals [47]:
            xmin = 268.369000
            xmax = 274.929000
            text = "What kind is it?"
        intervals [48]:
            xmin = 274.929000
            xmax = 311.390000
            text = "He's a mixture of various things. And what do I like about him? That's supposed to suggest that his tail wags. He's very friendly and cheery and always pleased to see you and very kind of affectionate and he's quite wee as well, so he doesn't take up too much space. And he does a funny thing where he chases his tail as well, which is quite amusing."
        intervals [49]:
            xmin = 311.390000
            xmax = 313.430000
            text = "Is he aware that it's his own tail he's chasing?"
        intervals [50]:
            xmin = 313.430000
            xmax = 313.560000
            text = ""
        intervals [51]:
            xmin = 313.560000
            xmax = 322.200000
            text = "It is, I think it is. He only does it after he's had his dinner and he'll just all of a sudden get up and start chasing his tail around the living room."
        intervals [52]:
            xmin = 322.200000
            xmax = 323.739000
            text = "An after-dinner dog then."
        intervals [53]:
            xmin = 323.739000
            xmax = 324.159000
            text = "Yeah."
        intervals [54]:
            xmin = 324.159000
            xmax = 328.960000
            text = "Probably when he was little he got lots of attention for doing it and has forever been conditioned."
        intervals [55]:
            xmin = 328.960000
            xmax = 329.480000
            text = ""
        intervals [56]:
            xmin = 329.480000
            xmax = 333.180000
            text = "Maybe. Where did you find this? Just down here?"
        intervals [57]:
            xmin = 333.180000
            xmax = 335.320000
            text = "Yeah."
        intervals [58]:
            xmin = 335.320000
            xmax = 376.360000
            text = "Okay. What are we doing next? Okay, we now need to discuss the project finance. So according to the brief, we're going to be selling this remote control for €25, and we're aiming to make €50 million. So we're going to be selling this one in international scale. And we don't want it to cost any more than €12.50, so 50% of the selling price."
        intervals [59]:
            xmin = 376.360000
            xmax = 376.429000
            text = ""
        intervals [60]:
            xmin = 376.429000
            xmax = 380.679000
            text = "Can we just go over that again? Sure."
        intervals [61]:
            xmin = 380.679000
            xmax = 385.520000
            text = "So basically— all right. Yeah. Okay."
        intervals [62]:
            xmin = 385.520000
            xmax = 394.985000
            text = "So cost, like production cost is— altogether €12.50, but selling price is— is that wholesale or retail? Like on the shelf?"
        intervals [63]:
            xmin = 394.985000
            xmax = 396.569000
            text = ""
        intervals [64]:
            xmin = 396.569000
            xmax = 398.689000
            text = "I don't know. I imagine that's a good question."
        intervals [65]:
            xmin = 398.689000
            xmax = 399.790000
            text = "Our sale."
        intervals [66]:
            xmin = 399.790000
            xmax = 420.350000
            text = "I imagine it probably is our sale actually, because it's probably up to the retailer to sell it for whatever price they want. But I don't know. I mean, do you think the fact that it's going to be sold internationally will have a bearing on how we design it at all? Yes. I think it will."
        intervals [67]:
            xmin = 420.350000
            xmax = 428.140000
            text = ""
        intervals [68]:
            xmin = 428.140000
            xmax = 433.860000
            text = "Right away I'm wondering if there's, like with DVD players, if there are zones."
        intervals [69]:
            xmin = 433.860000
            xmax = 435.860000
            text = "Oh yeah, regions and stuff."
        intervals [70]:
            xmin = 435.860000
            xmax = 436.830000
            text = "Frequencies or something."
        intervals [71]:
            xmin = 436.830000
            xmax = 437.100000
            text = ""
        intervals [72]:
            xmin = 437.100000
            xmax = 437.880000
            text = "Yeah."
        intervals [73]:
            xmin = 437.880000
            xmax = 446.050000
            text = "Okay. As well as characters, different keypad styles and symbols."
        intervals [74]:
            xmin = 446.050000
            xmax = 451.390000
            text = "Yeah. Well, for remote control, do you think that will be— I suppose it depends on how complicated our remote control is."
        intervals [75]:
            xmin = 451.390000
            xmax = 451.850000
            text = ""
        intervals [76]:
            xmin = 451.850000
            xmax = 460.260000
            text = "It does make sense from maybe the design point of view, because if you have more complicated characters like European languages, then you need more buttons."
        intervals [77]:
            xmin = 460.260000
            xmax = 460.550000
            text = ""
        intervals [78]:
            xmin = 460.550000
            xmax = 463.510000
            text = "Yeah, yeah, yeah."
        intervals [79]:
            xmin = 463.510000
            xmax = 476.770000
            text = "Okay. And then, and then the other thing, international, on topic of price, I'm thinking The price might appeal to a certain market in one region, whereas in another it'll be different."
        intervals [80]:
            xmin = 476.770000
            xmax = 477.800000
            text = ""
        intervals [81]:
            xmin = 477.800000
            xmax = 483.040000
            text = "So, what, just like in terms of the wealth of the country? Like how much money people have to spend on things?"
        intervals [82]:
            xmin = 483.040000
            xmax = 495.800000
            text = "Or just like basic product positioning. A €25 remote control might be a big hit in London, might not be such a big hit in Greece. Who knows?"
        intervals [83]:
            xmin = 495.800000
            xmax = 495.860000
            text = ""
        intervals [84]:
            xmin = 495.860000
            xmax = 503.684000
            text = "I see what you mean. Marketing. Good marketing thoughts. Oh gosh, I should be writing all this down. Um."
        intervals [85]:
            xmin = 503.684000
            xmax = 534.930000
            text = ""
        intervals [86]:
            xmin = 534.930000
            xmax = 545.510000
            text = "Right away I'm making some kind of assumptions about what information we're given here, thinking, okay, trendy probably means something other than just basic."
        intervals [87]:
            xmin = 545.510000
            xmax = 545.890000
            text = "Yeah."
        intervals [88]:
            xmin = 545.890000
            xmax = 556.289000
            text = "Something other than just standard. So I'm wondering right away, is selling €25, is that sort of— is this going to be like the premium product?"
        intervals [89]:
            xmin = 556.289000
            xmax = 557.299000
            text = ""
        intervals [90]:
            xmin = 557.299000
            xmax = 571.320000
            text = "Yeah, yeah. Like how much does a remote control cost? Well, €25, I mean, that's about like £18 or something, isn't it? Or no, is it as much as that? £16, £17, £18?"
        intervals [91]:
            xmin = 571.320000
            xmax = 572.120000
            text = "Yeah, I'd say so."
        intervals [92]:
            xmin = 572.120000
            xmax = 573.790000
            text = ""
        intervals [93]:
            xmin = 573.790000
            xmax = 589.030000
            text = "I don't know, I've never bought a remote control, so I don't know how good a remote control that would get you. But yeah, I suppose it has to look kind of cool, gimmicky."
        intervals [94]:
            xmin = 589.030000
            xmax = 591.530000
            text = "Right. Okay."
        intervals [95]:
            xmin = 591.530000
            xmax = 599.020000
            text = "Let me just scoot on ahead here. Okay. Well, does anybody have anything to add to that?"
        intervals [96]:
            xmin = 599.020000
            xmax = 600.000000
            text = ""
