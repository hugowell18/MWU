    item [5]:
        class = "IntervalTier"
        name = "transcript"
        xmin = 0
        xmax = 132.000000
        intervals: size = 29
        intervals [1]:
            xmin = 0.000000
            xmax = 0.530000
            text = ""
        intervals [2]:
            xmin = 0.530000
            xmax = 6.170000
            text = "Okay, Simone, um, let's go get something to eat. Let's go out to dinner. I'm really hungry."
        intervals [3]:
            xmin = 6.170000
            xmax = 7.020000
            text = ""
        intervals [4]:
            xmin = 7.020000
            xmax = 12.100000
            text = "Yeah, okay, me too. I'm really hungry as well. Uh, what is there to eat around here?"
        intervals [5]:
            xmin = 12.100000
            xmax = 28.730000
            text = "Well, around my house there's a few restaurants. Um, there's an Italian restaurant, there's a grilled chicken restaurant, there is a fish restaurant, And there is a family diner."
        intervals [6]:
            xmin = 28.730000
            xmax = 29.450000
            text = ""
        intervals [7]:
            xmin = 29.450000
            xmax = 32.049000
            text = "Hmm, family diner, what's that?"
        intervals [8]:
            xmin = 32.049000
            xmax = 32.169000
            text = ""
        intervals [9]:
            xmin = 32.169000
            xmax = 52.630000
            text = "Family diner is one of those restaurants that they serve many types of food. For example, they have noodles, they have pasta, they have hamburger, they have salad. Pretty much anyone in the family could order what they want. They have desserts, things like that."
        intervals [10]:
            xmin = 52.630000
            xmax = 52.720000
            text = ""
        intervals [11]:
            xmin = 52.720000
            xmax = 64.970000
            text = "Well, that makes sense. That's why it's called a family diner or family restaurant, because I guess everyone in the family will be happy if they eat there. Oh, you said Italian restaurant."
        intervals [12]:
            xmin = 64.970000
            xmax = 65.480000
            text = ""
        intervals [13]:
            xmin = 65.480000
            xmax = 83.960000
            text = "Yeah, there's an Italian restaurant. It's a very small family-owned Italian restaurant. They have really good pasta, fresh salads. They always have really good specials. The only problem is it's really crowded, and it's a little expensive because it's very popular."
        intervals [14]:
            xmin = 83.960000
            xmax = 84.370000
            text = ""
        intervals [15]:
            xmin = 84.370000
            xmax = 88.060000
            text = "Oh, really? Uh, do they have pizza? I like pizza."
        intervals [16]:
            xmin = 88.060000
            xmax = 88.170000
            text = ""
        intervals [17]:
            xmin = 88.170000
            xmax = 90.400000
            text = "Actually, they don't have pizza. They only have pasta."
        intervals [18]:
            xmin = 90.400000
            xmax = 90.869000
            text = ""
        intervals [19]:
            xmin = 90.869000
            xmax = 93.130000
            text = "Okay. Uh, what were the other choices?"
        intervals [20]:
            xmin = 93.130000
            xmax = 93.250000
            text = ""
        intervals [21]:
            xmin = 93.250000
            xmax = 97.510000
            text = "There's also a fish restaurant, and there's a grilled chicken restaurant."
        intervals [22]:
            xmin = 97.510000
            xmax = 101.710000
            text = "Grilled chicken? That's pretty general. How do they serve that?"
        intervals [23]:
            xmin = 101.710000
            xmax = 123.320000
            text = "It's actually— it's not a restaurant. This guy has a small stand. A very small area, and there's some small tables in front of it. And he just grills chicken kind of on the street, and then he has little tables in front of his booth or stall, and you eat chicken for really cheap."
        intervals [24]:
            xmin = 123.320000
            xmax = 125.150000
            text = "Oh, that sounds really cool. Let's do that."
        intervals [25]:
            xmin = 125.150000
            xmax = 125.160000
            text = ""
        intervals [26]:
            xmin = 125.160000
            xmax = 126.520000
            text = "Yeah, yeah, and they have beer too."
        intervals [27]:
            xmin = 126.520000
            xmax = 127.020000
            text = ""
        intervals [28]:
            xmin = 127.020000
            xmax = 130.420000
            text = "Oh yeah, I like beer. Cool, let's go. Okay."
        intervals [29]:
            xmin = 130.420000
            xmax = 132.000000
            text = ""
