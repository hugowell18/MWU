    item [5]:
        class = "IntervalTier"
        name = "transcript"
        xmin = 0
        xmax = 132
        intervals: size = 32
        intervals [1]:
            xmin = 0
            xmax = 0.53
            text = ""
        intervals [2]:
            xmin = 0.53
            xmax = 6.17
            text = "OK, Simon, let's go get something to eat? Let's go out to dinner. I'm really hungry."
        intervals [3]:
            xmin = 6.17
            xmax = 7.02
            text = ""
        intervals [4]:
            xmin = 7.02
            xmax = 12.1
            text = "Yeah, OK, me too. I'm really hungry as well. Ah, what is there to eat around here?"
        intervals [5]:
            xmin = 12.1
            xmax = 28.73
            text = "Well, around my house there's a few restaurants. Um, there's an Italian restaurant. There's a grilled chicken restaurant. There is a fish restaurant, and there is a family diner."
        intervals [6]:
            xmin = 28.73
            xmax = 29.45
            text = ""
        intervals [7]:
            xmin = 29.45
            xmax = 32.049
            text = "Family diner. What's that?"
        intervals [8]:
            xmin = 32.049
            xmax = 32.169
            text = ""
        intervals [9]:
            xmin = 32.169
            xmax = 52.63
            text = "The family diner is one of those restaurants that they serve many types of food, for example they have noodles, they have pasta, they have hamburger, they have salad. Pretty much anyone in the family could order what they want. They have desserts, things like that."
        intervals [10]:
            xmin = 52.63
            xmax = 52.72
            text = ""
        intervals [11]:
            xmin = 52.72
            xmax = 64.97
            text = "Well, that makes sense, that's why it's called a family diner, or family restaurant because I guess everyone in the family will be happy if they eat there. You said Italian restaurant."
        intervals [12]:
            xmin = 64.97
            xmax = 65.48
            text = ""
        intervals [13]:
            xmin = 65.48
            xmax = 83.96
            text = "Ah, yeah, there's an Italian restaurant. It's a very small family owned Italian restaurant. They have really good pasta,fresh salad. They always have really good specials. The only problem is that it's really crowded and it's a little expensive because it's very popular."
        intervals [14]:
            xmin = 83.96
            xmax = 84.37
            text = ""
        intervals [15]:
            xmin = 84.37
            xmax = 88.06
            text = "Oh, really. Ah, do they have pizza? I like pizza."
        intervals [16]:
            xmin = 88.06
            xmax = 88.17
            text = ""
        intervals [17]:
            xmin = 88.17
            xmax = 90.4
            text = "Actually, they don't have pizza. They only have pasta."
        intervals [18]:
            xmin = 90.4
            xmax = 90.869
            text = ""
        intervals [19]:
            xmin = 90.869
            xmax = 93.13
            text = "OK. What were the other choices?"
        intervals [20]:
            xmin = 93.13
            xmax = 93.25
            text = ""
        intervals [21]:
            xmin = 93.25
            xmax = 100.49
            text = "There's also a fish restaurant and there's a grilled chicken restaurant. A grilled chicken. That's pretty general."
        intervals [22]:
            xmin = 100.49
            xmax = 101.71
            text = "How do they serve that?"
        intervals [23]:
            xmin = 101.71
            xmax = 123.32
            text = "It's actually, it's not a restaurant. This guy has a small stand, a very small area, and there are some small tables in front of it, and he just grills chicken, kind of on the street, and then he has little tables in front of his booth or stall and you eat chicken for really cheap."
        intervals [24]:
            xmin = 123.32
            xmax = 125.15
            text = "Oh, that sounds really cool. Let's do that."
        intervals [25]:
            xmin = 125.15
            xmax = 125.16
            text = ""
        intervals [26]:
            xmin = 125.16
            xmax = 126.52
            text = "Yeah, yeah, and they have beer, too."
        intervals [27]:
            xmin = 126.52
            xmax = 127.02
            text = ""
        intervals [28]:
            xmin = 127.02
            xmax = 128.69
            text = "Oh, yeah, I like beer."
        intervals [29]:
            xmin = 128.69
            xmax = 128.76
            text = ""
        intervals [30]:
            xmin = 128.76
            xmax = 129.94
            text = "Cool, let's go."
        intervals [31]:
            xmin = 129.94
            xmax = 130.42
            text = "OK."
        intervals [32]:
            xmin = 130.42
            xmax = 132
            text = ""
